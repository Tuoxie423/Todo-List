<view class="page">
  <view class="hero">
    <text class="eyebrow">Todo-list</text>
    <text class="title">查看你的私人任务清单</text>
    <text class="lead">小程序会使用微信账号自动登录。每个微信用户拥有独立清单，别人不能访问你的数据。</text>
  </view>

  <view class="entry-panel">
    <view class="wechat-panel">
      <view>
        <text class="label">微信登录</text>
        <text class="wechat-name" wx:if="{{user}}">{{user.username}}</text>
        <text class="wechat-name" wx:else>{{loginLoading ? '登录中...' : '未登录'}}</text>
      </view>
      <button class="clear-button" loading="{{loginLoading}}" disabled="{{loginLoading}}" bindtap="relogin">重新登录</button>
    </view>

    <view class="field">
      <text class="label">清单名称</text>
      <input class="input" value="{{roomName}}" maxlength="40" placeholder="例如：Go 后端练习" bindinput="onListNameInput" confirm-type="go" bindconfirm="enterListSubmit" disabled="{{!user || loginLoading}}" />
    </view>

    <button class="enter-button" loading="{{loading}}" disabled="{{loading || !user || loginLoading}}" bindtap="enterListSubmit">查看清单</button>
    <text class="message">{{message}}</text>

    <view class="history-panel">
      <view class="history-heading">
        <text class="history-title">历史清单</text>
        <button class="clear-button" disabled="{{!hasHistory}}" bindtap="clearHistory">清空</button>
      </view>

      <view wx:if="{{!hasHistory}}" class="history-empty">还没有查看过清单</view>
      <view wx:else class="history-list">
        <button wx:for="{{history}}" wx:key="id" class="history-item" data-id="{{item.id}}" bindtap="enterHistoryList">
          <text>{{item.name}}</text>
          <text class="visited-at">{{item.visitedAtText}}</text>
        </button>
      </view>
    </view>
  </view>

  <view class="hint-grid">
    <view class="hint">
      <text class="hint-title">微信登录</text>
      <text class="hint-copy">无需输入账号密码，打开后自动识别当前微信用户</text>
    </view>
    <view class="hint">
      <text class="hint-title">私人清单</text>
      <text class="hint-copy">清单和任务都绑定到当前微信账号</text>
    </view>
  </view>
</view>