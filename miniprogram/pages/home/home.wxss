.page {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
  background:
    linear-gradient(90deg, rgba(31, 37, 32, 0.05) 1px, transparent 1px),
    linear-gradient(rgba(31, 37, 32, 0.05) 1px, transparent 1px),
    #f7f1e4;
  background-size: 44rpx 44rpx;
}

.hero {
  padding: 40rpx 0 32rpx;
}

.eyebrow {
  display: block;
  color: #206b4f;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.title {
  display: block;
  margin-top: 18rpx;
  color: #1f2520;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 78rpx;
  font-weight: 800;
  line-height: 0.94;
}

.lead {
  display: block;
  margin-top: 28rpx;
  color: #4e574b;
  font-size: 30rpx;
  line-height: 1.7;
}

.entry-panel,
.hint {
  border: 1rpx solid rgba(31, 37, 32, 0.14);
  border-radius: 12rpx;
  background: rgba(255, 250, 240, 0.92);
  box-shadow: 0 24rpx 60rpx rgba(44, 37, 25, 0.12);
}

.entry-panel {
  padding: 28rpx;
}

.field {
  display: block;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: #66705f;
  font-size: 26rpx;
  font-weight: 800;
}

.input {
  width: 100%;
  min-height: 96rpx;
  padding: 0 24rpx;
  border: 1rpx solid #cfc4ab;
  border-radius: 12rpx;
  color: #1f2520;
  background: #fffaf0;
}

.enter-button {
  min-height: 96rpx;
  margin-top: 24rpx;
  color: #fffaf0;
  background: #1f2520;
  font-size: 30rpx;
  font-weight: 850;
}

.message {
  display: block;
  min-height: 46rpx;
  padding-top: 18rpx;
  color: #114632;
  font-size: 26rpx;
  font-weight: 750;
}

.history-panel {
  margin-top: 18rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #d9cfb8;
}

.history-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-title {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 34rpx;
  font-weight: 800;
}

.clear-button {
  width: 112rpx;
  min-height: 62rpx;
  color: #66705f;
  background: #eee5d2;
  font-size: 24rpx;
  font-weight: 800;
}

.clear-button[disabled] {
  opacity: 0.46;
}

.history-empty {
  padding-top: 24rpx;
  color: #66705f;
  font-size: 28rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d9cfb8;
  color: #1f2520;
  background: #fffaf0;
  font-size: 28rpx;
  font-weight: 800;
  text-align: left;
}

.history-item + .history-item {
  margin-top: 14rpx;
}

.visited-at {
  color: #66705f;
  font-size: 24rpx;
  font-weight: 750;
}

.hint-grid {
  display: flex;
  margin-top: 24rpx;
}

.hint {
  flex: 1;
  min-height: 150rpx;
  padding: 24rpx;
}

.hint + .hint {
  margin-left: 18rpx;
}

.hint-title {
  display: block;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 34rpx;
  font-weight: 800;
}

.hint-copy {
  display: block;
  margin-top: 12rpx;
  color: #66705f;
  font-size: 25rpx;
  line-height: 1.5;
}
